# Supabase Database URL (Direct Connection or Connection Pooler)
# Format: postgresql://postgres.[username]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Supabase Auth configuration
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret-from-settings

# Google AI Studio API Key (For Gemini Flash)
GEMINI_API_KEY=your-gemini-api-key
